# =========================
# Dataset
# =========================
# Dataset mentah biasanya besar, jadi jangan dimasukkan ke repo
dataset/raw/*
!dataset/raw/.gitkeep

# Foto label makanan biasanya besar/banyak, jadi jangan dimasukkan ke repo
dataset/images/*
!dataset/images/.gitkeep

# Dataset hasil olahan boleh masuk repo jika kecil.
# Kalau processed dataset nanti besar, aktifkan ignore di bawah:
# dataset/processed/*
# !dataset/processed/.gitkeep

